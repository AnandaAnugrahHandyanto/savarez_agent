# MES 巡检环境变量配置
# 复制此文件为 .env 并填入实际值
# 所有密钥通过环境变量传递，不写入 YAML 配置文件

# ── Oracle 数据库 ──
ORACLE_PASSWORD=

# ── GitLab ──
GITLAB_TOKEN=

# ── 飞书 ──
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOME_CHANNEL=

# ── 模型 API ──
QWEN_API_KEY=
OPENAI_API_KEY=

# ── SSH 默认密钥（可选，也可在 YAML 中按节点配置） ──
# MES_SSH_KEY_PATH=~/.ssh/id_rsa
