# Nash AI — VPS secrets
# Copy to: ~/.hermes/.env
# Never commit the real .env file

# =============================================================================
# Anthropic (used by Prism for LLM routing — Prism reads this)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Telegram bot — create via @BotFather
# =============================================================================
TELEGRAM_BOT_TOKEN=          # From @BotFather: /newbot
TELEGRAM_ALLOWED_USERS=      # Your Telegram numeric user ID (get via @userinfobot)
TELEGRAM_HOME_CHANNEL=       # Chat ID where cron messages go (your DM with the bot, or a group)

# =============================================================================
# Voice transcription (free tier — groq.com)
# =============================================================================
GROQ_API_KEY=                # Get at: console.groq.com/keys

# =============================================================================
# Optional — fallback if Prism is down
# =============================================================================
# OPENROUTER_API_KEY=        # Uncomment to allow OpenRouter as Prism fallback
