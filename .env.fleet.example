# Hermes Agent Fleet — Environment Variables
# Copy this file to .env.fleet and fill in all values before deploying.
# Run with: docker compose --env-file .env.fleet up -d

# =============================================================================
# SHARED — one API key used by all containers
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# A2A BEARER TOKENS — each agent requires its own secret key
# Generate with: openssl rand -hex 32
# These are used to authenticate A2A requests TO each container.
# They are also injected into docker/config.yaml so agents can call each other.
# =============================================================================

# Harry Potter
HARRY_A2A_KEY=
HERMIONE_A2A_KEY=
RON_A2A_KEY=
DUMBLEDORE_A2A_KEY=
SNAPE_A2A_KEY=
HAGRID_A2A_KEY=
VOLDEMORT_A2A_KEY=
LUNA_A2A_KEY=
NEVILLE_A2A_KEY=
DRACO_A2A_KEY=

# Marvel
