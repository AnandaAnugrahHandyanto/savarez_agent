{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/schemas/learning-foundry-extraction.schema.json",
  "title": "Hermes Learning Foundry Extraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "batch_id",
    "batch_theme",
    "source_window",
    "privacy_level",
    "sources",
    "claims",
    "review_packet"
  ],
  "properties": {
    "batch_id": {
      "type": "string",
      "minLength": 6,
      "description": "Stable batch identifier such as lf-2026-05-22-operating-model-001."
    },
    "batch_theme": {
      "type": "string",
      "minLength": 8
    },
    "source_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date", "scope_note"],
      "properties": {
        "start_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "end_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "scope_note": {
          "type": "string",
          "minLength": 12
        }
      }
    },
    "privacy_level": {
      "type": "string",
      "enum": ["private_internal", "redacted_internal", "publishable_after_review"]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_type", "locator", "why_included"],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 3
          },
          "source_type": {
            "type": "string",
            "enum": [
              "memory_registry",
              "rollout_summary",
              "raw_session",
              "repo_doc",
              "repo_artifact",
              "git_history",
              "obsidian_note",
              "atlas_file",
              "test_output",
              "other"
            ]
          },
          "locator": {
            "type": "string",
            "minLength": 4
          },
          "why_included": {
            "type": "string",
            "minLength": 12
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "claim_type",
          "claim",
          "evidence",
          "confidence_grade",
          "transferability",
          "limitations",
          "status"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 4
          },
          "claim_type": {
            "type": "string",
            "enum": [
              "decision",
              "failure_pattern",
              "recovery_pattern",
              "operating_principle",
              "implementation_pattern",
              "approval_boundary",
              "business_lesson",
              "framework_candidate"
            ]
          },
          "claim": {
            "type": "string",
            "minLength": 20
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_id", "quote_or_summary", "locator"],
              "properties": {
                "source_id": {
                  "type": "string",
                  "minLength": 3
                },
                "quote_or_summary": {
                  "type": "string",
                  "minLength": 12
                },
                "locator": {
                  "type": "string",
                  "minLength": 4
                }
              }
            }
          },
          "confidence_grade": {
            "type": "string",
            "enum": ["observed", "repeated", "proven", "teachable", "framework_grade"]
          },
          "transferability": {
            "type": "object",
            "additionalProperties": false,
            "required": ["audience", "why_it_transfers", "where_it_may_not_apply"],
            "properties": {
              "audience": {
                "type": "string",
                "minLength": 5
              },
              "why_it_transfers": {
                "type": "string",
                "minLength": 15
              },
              "where_it_may_not_apply": {
                "type": "string",
                "minLength": 10
              }
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "needs_evidence",
              "verified_learning",
              "framework_draft",
              "teaching_asset_candidate",
              "rejected",
              "parked"
            ]
          },
          "rejection_reason": {
            "type": "string"
          }
        }
      }
    },
    "review_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strongest_findings",
        "weak_or_rejected_findings",
        "recommended_next_batch",
        "human_review_needed"
      ],
      "properties": {
        "strongest_findings": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 12
          }
        },
        "weak_or_rejected_findings": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 12
          }
        },
        "recommended_next_batch": {
          "type": "string",
          "minLength": 12
        },
        "human_review_needed": {
          "type": "boolean"
        }
      }
    }
  }
}
