APP_ENV=development
APP_NAME=Internal Knowledge Bot API
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
DATABASE_URL=sqlite:///./knowledge_bot.db
EMBEDDING_DIM=256
TOP_K_DEFAULT=8
MIN_CONFIDENCE_FOR_AUTO_ANSWER=0.22
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# v2.1+/v3 operational knobs
DEFAULT_HANDOFF_SLA_MINUTES=1440
FRESHNESS_HTTP_TIMEOUT_SECONDS=3
INGESTION_WORKER_ENABLED=false
INGESTION_WORKER_INTERVAL_SECONDS=15
