###################################################
# ✅ HERMES RAILWAY CONFIG (ADMIN UI COMPATIBLE)
###################################################

############################
# 🤖 LLM SETTINGS (REQUIRED)
############################

# Which provider to use:
# openrouter OR gemini
LLM_PROVIDER=openrouter

# Model name
# OpenRouter: openrouter/auto
# Gemini: gemini-2.5-flash
LLM_MODEL=openrouter/auto


############################
# 🔑 API KEYS (CHOOSE ONE)
############################

# ✅ OpenRouter
OPENROUTER_API_KEY=

# ✅ Google Gemini
GOOGLE_API_KEY=


############################
# 📱 MESSAGING (REQUIRED)
############################

# Telegram (recommended)
TELEGRAM_BOT_TOKEN=

# Optional platforms
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=


############################
# 🛠 OPTIONALS
############################

GITHUB_TOKEN=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=
FAL_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
VOICE_TOOLS_OPENAI_KEY=
HONCHO_API_KEY=


############################
# ⚙️ GATEWAY SETTINGS
############################

GATEWAY_ALLOW_ALL_USERS=false


############################
# 🔐 ADMIN (AUTO SET)
############################

ADMIN_USERNAME=admin
ADMIN_PASSWORD=
