#!/bin/sh
# Bootstrap hermes dependencies on first container start.
#
# This script runs as root via s6-overlay cont-init.d (before any user
# services start). It installs Python deps, Node deps, and Playwright
# Chromium the first time the container boots, then marks itself done so
# subsequent restarts are instant.
#
# Motivation: the Docker image ships only system tools + source code.
# All heavy dependency downloads (uv sync, npm install, playwright
# install) are deferred here so CI builds complete in < 5 minutes
# instead of timing out after 20–35 minutes.
#
# Marker file: $INSTALL_DIR/.bootstrap_done
#   - Absent  → first boot, run full install
#   - Present → already bootstrapped, skip everything (fast path)
#
# All file writes happen as the hermes user via s6-setuidgid so
# ownership is correct from the start.

set -eu

INSTALL_DIR="/opt/hermes"
BOOTSTRAP_DONE_MARKER="$INSTALL_DIR/.bootstrap_done"

# ── Fast path ────────────────────────────────────────────────────────
if [ -f "$BOOTSTRAP_DONE_MARKER" ]; then
    echo "[bootstrap] Dependencies already installed — skipping."
    exit 0
fi

echo "[bootstrap] ============================================="
echo "[bootstrap] First boot: installing hermes dependencies."
echo "[bootstrap] This takes 10–20 min. Subsequent starts are instant."
echo "[bootstrap] ============================================="

# Ensure the install dir is writable by the hermes user so all
# subsequent s6-setuidgid calls can create files/dirs freely.
chown -R hermes:hermes "$INSTALL_DIR" 2>/dev/null || \
    echo "[bootstrap] Warning: chown $INSTALL_DIR failed (rootless?), continuing"

# ── Python dependencies (uv sync) ───────────────────────────────────
# Installs into $INSTALL_DIR/.venv (the project-local virtualenv that
# uv creates when run from $INSTALL_DIR with a pyproject.toml present).
# --frozen: respect uv.lock exactly; never re-resolve
# --no-install-project: skip the editable link for now (done next step)
# extras mirror the original Dockerfile uv sync invocation
echo "[bootstrap] [1/4] Installing Python dependencies (uv sync)..."
cd "$INSTALL_DIR"
s6-setuidgid hermes /usr/local/bin/uv sync \
    --frozen \
    --no-install-project \
    --extra all --extra messaging --extra anthropic --extra bedrock --extra azure-identity \
    2>&1 | sed 's/^/[bootstrap][uv] /'

# ── Editable hermes-agent install ───────────────────────────────────
# Creates the .pth / egg-link so `import hermes_cli` resolves to the
# source tree. --no-deps: deps are already in place from the sync above.
echo "[bootstrap] [2/4] Installing hermes-agent (editable link)..."
s6-setuidgid hermes /usr/local/bin/uv pip install \
    --no-cache-dir --no-deps -e "$INSTALL_DIR" \
    2>&1 | sed 's/^/[bootstrap][uv] /'

# ── Node.js dependencies ─────────────────────────────────────────────
# Only root-level package.json (agent-browser runtime dependency).
# web/ and ui-tui/ are not needed in this deployment (k8s, no frontend).
echo "[bootstrap] [3/4] Installing Node.js dependencies (npm install)..."
s6-setuidgid hermes npm install \
    --prefix "$INSTALL_DIR" \
    --prefer-offline --no-audit \
    2>&1 | sed 's/^/[bootstrap][npm] /'
npm cache clean --force 2>/dev/null || true

# ── Playwright Chromium ───────────────────────────────────────────────
# Installs headless Chromium under $PLAYWRIGHT_BROWSERS_PATH
# (=/opt/hermes/.playwright). The stage2-hook Chromium-discovery logic
# reads this env var and exports AGENT_BROWSER_EXECUTABLE_PATH into the
# s6 container environment on every subsequent boot.
echo "[bootstrap] [4/4] Installing Playwright Chromium..."
export PLAYWRIGHT_BROWSERS_PATH="$INSTALL_DIR/.playwright"
s6-setuidgid hermes npx playwright install --with-deps chromium --only-shell \
    2>&1 | sed 's/^/[bootstrap][playwright] /'

# ── Fix ownership ─────────────────────────────────────────────────────
# Re-chown after install so the hermes user owns everything it just created.
for tree in .venv node_modules .playwright; do
    if [ -d "$INSTALL_DIR/$tree" ]; then
        chown -R hermes:hermes "$INSTALL_DIR/$tree" 2>/dev/null || \
            echo "[bootstrap] Warning: chown $INSTALL_DIR/$tree failed (rootless?)"
    fi
done

# ── Mark bootstrap complete ───────────────────────────────────────────
printf '%s\n' "$(date -Iseconds)" > "$BOOTSTRAP_DONE_MARKER"
chown hermes:hermes "$BOOTSTRAP_DONE_MARKER"

echo "[bootstrap] ============================================="
echo "[bootstrap] Bootstrap complete. Container is now ready."
echo "[bootstrap] ============================================="
