# docker compose env file for the MS Teams adapter.  Copy to
# docker/.env.msteams and fill in real values.  Everything here is
# consumed by the gateway when the container starts — see
# docker/compose.msteams.yml.

# ─── Required: Azure App Registration ────────────────────────────────
MSTEAMS_APP_ID=00000000-0000-0000-0000-000000000000
MSTEAMS_TENANT_ID=common
# For smoke tests you can leave this blank and use MSTEAMS_DM_POLICY=open;
# for real Teams traffic set it to the client secret you created in
# Azure Portal → Certificates & secrets.
MSTEAMS_APP_PASSWORD=

# ─── Optional: federated auth (comment MSTEAMS_APP_PASSWORD above if used) ───
# MSTEAMS_AUTH_TYPE=federated
# MSTEAMS_CERTIFICATE_PATH=/opt/data/msteams/cert.pem
# MSTEAMS_CERTIFICATE_THUMBPRINT=AABBCC...
# MSTEAMS_USE_MANAGED_IDENTITY=false
# MSTEAMS_MANAGED_IDENTITY_CLIENT_ID=

# ─── Access control ──────────────────────────────────────────────────
# Smoke test: open lets any Teams user reach the bot.  Production: use
# "pairing" or "allowlist" with MSTEAMS_ALLOW_FROM populated.
MSTEAMS_DM_POLICY=pairing
MSTEAMS_ALLOW_FROM=
MSTEAMS_GROUP_ALLOW_FROM=
MSTEAMS_REQUIRE_MENTION=true

# ─── SharePoint (optional; required for channel file uploads) ────────
MSTEAMS_SHAREPOINT_SITE_ID=

# ─── Model provider (REQUIRED — the agent can't reason without one) ──
# Uncomment and fill in at least one.  Hermes picks the first configured
# provider; you can switch later inside the running agent with `hermes model`.
#
# Nous Portal — first-party host with Hermes-trained models:
# NOUS_API_KEY=
# OpenRouter — 200+ models, easiest mixed-provider setup:
# OPENROUTER_API_KEY=
# Anthropic direct:
# ANTHROPIC_API_KEY=
# OpenAI:
# OPENAI_API_KEY=
# Optional: Whisper / OpenAI TTS for voice messages:
# VOICE_TOOLS_OPENAI_KEY=

# ─── Other platforms (optional; turn any of these on by uncommenting) ─
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# ─── Gateway safety ──────────────────────────────────────────────────
# Leave GATEWAY_ALLOW_ALL_USERS unset unless you intentionally want
# open access — the gateway denies unknown users by default.
