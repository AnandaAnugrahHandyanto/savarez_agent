+    def _translate_container_path_to_host(self, path: str) -> str:
+        """Translate a container file path to the equivalent host path.
+
+        When Hermes runs in Docker with /opt/data as HERMES_HOME and signal-cli
+        runs on the host (via host.docker.internal), attachment paths like
+        /opt/data/cache/audio/tts_123.ogg are invisible to signal-cli.
+
+        If SIGNAL_HOST_DATA_DIR is set (e.g. ~/.hermes), this replaces the
+        container HERMES_HOME prefix with the host path.
+        Without SIGNAL_HOST_DATA_DIR, the path is returned unchanged.
+        """
+        if (
+            not self._host_data_dir
+            or not self._container_data_prefix
+            or not path.startswith(self._container_data_prefix)
+        ):
+            return path
 
+        host_data = os.path.expanduser(self._host_data_dir)
+        relative = path[len(self._container_data_prefix):]
+        translated = host_data.rstrip("/") + "/" + relative.lstrip("/")
+        logger.debug(
+            "Signal: translated container path %s → host path %s",
+            path, translated,
+        )
+        return translated
+
