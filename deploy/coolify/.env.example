# Copy to .env for local `docker compose up` testing, or paste these keys
# one-by-one into Coolify's "Environment Variables" UI (mark secrets).
# This file is an example only — never commit real keys.

# ─── Required ────────────────────────────────────────────────────────────────
NEBIUS_API_KEY=

# ─── Model selection (optional — good defaults are in docker-compose.yml) ────
# HERMES_PRIMARY_MODEL=Qwen/Qwen3-Coder-480B-A35B-Instruct
# HERMES_FALLBACK_MODEL=deepseek-ai/DeepSeek-V3
# NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1/

# ─── Agent authorization ─────────────────────────────────────────────────────
# HERMES_YOLO_MODE=1

# ─── Volume ownership (align with host if you bind-mount instead of named volume)
# HERMES_UID=10000
# HERMES_GID=10000

# ─── Messaging (enable whichever gateways you use) ───────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# ─── Optional tool keys ──────────────────────────────────────────────────────
# FIRECRAWL_API_KEY=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# FAL_KEY=
# ELEVENLABS_API_KEY=
