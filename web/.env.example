# Hermes chat studio / dashboard env vars
# Copy to .env.local (or configure in your deploy platform)

# Production API base URL for the Hermes backend.
# Leave empty for same-origin deployments.
VITE_HERMES_API_BASE_URL=

# Base URL that serves the SPA shell and the injected session token.
# Usually the same as API base when the frontend and backend are hosted together.
VITE_HERMES_AUTH_BASE_URL=

# Local dev proxy target for Vite (`npm run dev`).
# Defaults to the local Hermes dashboard backend.
VITE_HERMES_API_PROXY_URL=http://127.0.0.1:9119

# Backend CORS allowlist for deployed frontends.
# Comma-separated list of exact origins, for example:
# HERMES_WEB_CORS_ORIGINS=https://studio.example.com,https://preview.example.com
HERMES_WEB_CORS_ORIGINS=

# Optional public login gate for the web studio backend.
# HERMES_WEB_LOGIN_EMAIL=renato.mott@gmail.com
# HERMES_WEB_LOGIN_PASSWORD=
# HERMES_WEB_LOGIN_SECRET=
# HERMES_WEB_LOGIN_TOKEN_TTL_REMEMBER_SECONDS=2592000
# HERMES_WEB_LOGIN_TOKEN_TTL_SESSION_SECONDS=43200
