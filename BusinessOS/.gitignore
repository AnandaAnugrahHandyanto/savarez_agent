# BusinessOS: version the engineering scaffold, ignore live operational state.

# Python/runtime noise
__pycache__/
*.py[cod]
.pytest_cache/

# Secrets / local overrides
.env
*.local

# Raw intake and filed business artifacts
00_INBOX/**
!00_INBOX/**/
!00_INBOX/**/.gitkeep
01_DOCUMENTS/**
!01_DOCUMENTS/**/
!01_DOCUMENTS/**/.gitkeep
99_ARCHIVE/**
!99_ARCHIVE/**/
!99_ARCHIVE/**/.gitkeep

# Real entity-instance records stay local by default
02_ENTITIES/**/*.json

# Local operational/state data
03_DATA/db/*.db*
03_DATA/exports/**
!03_DATA/exports/**/
!03_DATA/exports/**/.gitkeep
03_DATA/extracted-text/**
03_DATA/imports/**
!03_DATA/imports/**/
!03_DATA/imports/**/.gitkeep
03_DATA/logs/**
!03_DATA/logs/**/
!03_DATA/logs/**/.gitkeep
03_DATA/metadata/**
03_DATA/normalized/**
!03_DATA/normalized/**/
!03_DATA/normalized/**/.gitkeep

# Generated reports stay local; keep directory placeholders only
05_REPORTS/**/*.md
05_REPORTS/**/*.csv
!05_REPORTS/**/.gitkeep

# Generated reply/review exports
03_DATA/exports/outbound-replies/**
03_DATA/exports/customer-feedback/**

# Test/build artifacts
tests/__pycache__/
04_AUTOMATIONS/scripts/__pycache__/
