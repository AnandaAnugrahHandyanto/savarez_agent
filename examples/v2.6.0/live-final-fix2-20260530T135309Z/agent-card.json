  "defaultOutputModes": [
    "text"
  ],
  "additionalInterfaces": [
    {
      "url": "http://192.168.31.247:18800/a2a/jsonrpc",
      "transport": "JSONRPC"
    },
    {
      "url": "http://192.168.31.247:18800/a2a/rest",
      "transport": "HTTP+JSON"
    },
    {
      "url": "192.168.31.247:18801",
      "transport": "GRPC"
    }
  ]
