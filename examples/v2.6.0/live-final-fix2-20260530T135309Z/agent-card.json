{
  "protocolVersion": "0.3.0",
  "version": "1.0.0",
  "name": "OpenClaw 247 A2A Gateway",
  "description": "A2A bridge for OpenClaw 247",
  "url": "http://192.168.31.247:18800/a2a/jsonrpc",
  "skills": [],
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "stateTransitionHistory": false
