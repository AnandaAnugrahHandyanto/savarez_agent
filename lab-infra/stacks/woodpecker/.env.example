# Required — copy to .env and fill in
# Never commit .env to git

# GitHub OAuth App
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Homepage URL: https://woodpecker.jaxmind.xyz
# Callback URL: https://woodpecker.jaxmind.xyz/authorize
WOODPECKER_GITHUB_CLIENT=your_github_oauth_client_id
WOODPECKER_GITHUB_SECRET=your_github_oauth_client_secret

# Shared secret between server and agent — generate with: openssl rand -hex 32
WOODPECKER_AGENT_SECRET=generate_with_openssl_rand_hex_32

# Your GitHub username — gets admin access to Woodpecker
WOODPECKER_ADMIN=pablots99

# Token for Prometheus scraping — generate with: openssl rand -hex 16
WOODPECKER_PROMETHEUS_TOKEN=generate_with_openssl_rand_hex_16
