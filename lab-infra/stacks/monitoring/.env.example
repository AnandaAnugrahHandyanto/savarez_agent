# Required — copy this to .env and fill in values
# Never commit .env to git

# Alertmanager → Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Basic auth for VictoriaMetrics (Grafana Cloud datasource)
# Generate: htpasswd -nB admin | sed -e s/\\$/\\$\\$/g
VM_DASHBOARD_AUTH=admin:$$2y$$05$$changeme

# Basic auth for Loki (Grafana Cloud datasource)
LOKI_DASHBOARD_AUTH=admin:$$2y$$05$$changeme
