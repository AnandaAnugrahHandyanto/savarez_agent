# Required — copy to /lab/stacks/jax-control-plane/.env and fill in
# Never commit real secrets to git

APP_NAME=Jax Control Plane
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8085
LOG_LEVEL=info
HERMES_HOME=/home/pablo/.hermes
SQLITE_PATH=./data/jax_control_plane.db
POLL_INTERVAL_SECONDS=60

# Required for live Linear metadata
LINEAR_API_KEY=lin_api_...

# Traefik routing + basic auth
JAX_CONTROL_PLANE_HOST=control.jaxmind.xyz
# Generate with: docker run --rm httpd:2.4-alpine htpasswd -nbB admin '<password>' | sed -e 's/\$/\$\$/g'
JAX_CONTROL_PLANE_AUTH=admin:$$2y$$05$$replace-with-bcrypt-hash
# Optional operator note only — do not commit real password values
JAX_CONTROL_PLANE_PASSWORD=replace-me
